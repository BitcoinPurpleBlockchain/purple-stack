# bitcoinpurple.conf — full node + ElectrumX backend (Docker)

# Network
#testnet=0
listen=1
discover=1
port=13496
maxconnections=125
seednode=node3.walletbuilders.com
addnode=173.212.224.67:13496
addnode=144.91.120.225:13496
addnode=66.94.115.80:13496
addnode=89.117.149.130:13496
addnode=84.247.169.248:13496

# Indexes (txindex required by ElectrumX; incompatible with prune)
txindex=1
#prune=0

# Performance
dbcache=450
maxmempool=300
mempoolexpiry=336

# RPC — credentials are set via RPC_USER / RPC_PASSWORD in .env
server=1
rpcport=13495
rpcbind=0.0.0.0
rpcallowip=127.0.0.1
rpcallowip=10.0.0.0/8
rpcallowip=172.16.0.0/12
rpcallowip=192.168.0.0/16
rpcthreads=4
rpcworkqueue=64   # raised from default 16 — ElectrumX issues many parallel calls
rpcservertimeout=30

# ZMQ (ElectrumX autodiscovers via getzmqnotifications)
zmqpubrawblock=tcp://0.0.0.0:28332
zmqpubrawtx=tcp://0.0.0.0:28333
zmqpubhashblock=tcp://0.0.0.0:28334
zmqpubhashtx=tcp://0.0.0.0:28335
zmqpubrawblockhwm=500
zmqpubrawtxhwm=500

# Mining
blockmaxweight=3996000
blockmintxfee=0.00001
#disablewallet=1
