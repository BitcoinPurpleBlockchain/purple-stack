# RPC credentials — required, single source of truth for all three services.
# Do NOT set rpcuser/rpcpassword in bitcoinpurple.conf; set them only here.
RPC_USER=your_rpcuser
RPC_PASSWORD=your_strong_password

# ElectrumX bootstrap peers — comma-separated list of known BTCP ElectrumX servers.
# Format: "host t" (TCP) or "host s t" (TCP + SSL). Recommended: use "t" only.
# Adding even a single known node is enough: ElectrumX discovers the rest automatically.
# Example: ELECTRUMX_PEERS=1.2.3.4 t,5.6.7.8 t
# ELECTRUMX_PEERS=

# ElectrumX ports
ELECTRUMX_TCP_PORT=50001
ELECTRUMX_SSL_PORT=50002
DASHBOARD_PORT=8080

# Dashboard auth for external clients (non-RFC1918 source IPs)
DASHBOARD_AUTH_USERNAME=admin
DASHBOARD_AUTH_PASSWORD=change-me-now

# API key for external API calls (/api/*)
# Also used to sign dashboard session cookies
API_KEY=change-me-to-a-long-random-api-key

# Session duration for dashboard login (hours). Default: 12
DASHBOARD_SESSION_HOURS=1
# Set to true if the dashboard is served over HTTPS
DASHBOARD_SESSION_COOKIE_SECURE=false
